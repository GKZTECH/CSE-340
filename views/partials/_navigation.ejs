<nav class="main-nav">
  <div class="nav-container">
    <div class="logo">
      <a href="/">
        <img src="/images/icon.png" alt="CSE Motors Logo" class="nav-logo">
        <span class="logo-text">CSE Motors</span>
      </a>
    </div>
    <div class="nav-menu" id="nav-menu">
      <ul class="nav-links">
        <%- nav %>
      </ul>
      <div class="nav-actions">
        <% if (loggedIn) { %>
          <!-- Show welcome message and logout link when logged in -->
          <a href="/account" class="welcome-link">
            <span class="welcome-icon">👋</span>
            <span class="welcome-text">Welcome <%= user.account_firstname %></span>
          </a>
          <a href="/account/logout" class="account-link">
            <span class="account-icon">🚪</span>
            <span class="account-text">Logout</span>
          </a>
        <% } else { %>
          <!-- Show My Account link when not logged in -->
          <a href="/account/login" class="account-link">
            <span class="account-icon">👤</span>
            <span class="account-text">My Account</span>
          </a>
        <% } %>
      </div>
    </div>
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="nav-menu">
      <span class="hamburger"></span>
    </button>
  </div>
</nav>
<script src="/js/navigation.js" defer></script>